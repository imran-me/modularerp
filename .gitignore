# Dev-machine tooling only — the deployed site stays no-build static.
node_modules/

# OS noise
Thumbs.db
.DS_Store

# Claude verification harness temp files (never commit)
__*.html

# Laravel backend: never commit deps or secrets
platform/backend/vendor/
platform/backend/.env
platform/backend/storage/*.key
platform/backend/bootstrap/cache/*.php

# Laravel backend: symlinks deploy.sh creates into public/ every run.
# These point to ABSOLUTE paths on whichever machine ran deploy.sh — meaningless
# (and would overwrite the server's correct symlinks) if committed. Never track.
platform/backend/public/platform/
platform/backend/public/companies/
platform/backend/public/favicon.svg
.parity/
